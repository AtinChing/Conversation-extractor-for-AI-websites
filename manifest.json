{
  "manifest_version": 3,
  "name": "Conversation Extractor for AI Websites",
  "description": "Export ChatGPT, Claude, and Gemini conversations to Markdown, JSON, or plain text.",
  "version": "1.3.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Conversation Extractor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "shared/page-bridge.js",
        "shared/main/chatgpt-fast.js",
        "shared/main/claude-fast.js",
        "shared/main/gemini-fast.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "shared/namespace.js",
        "shared/download.js",
        "shared/format-registry.js",
        "shared/formats/markdown.js",
        "shared/formats/json.js",
        "shared/formats/txt.js",
        "shared/scroll-harvest.js",
        "shared/scrape-claude.js",
        "shared/scrape-chatgpt.js",
        "shared/scrape-gemini.js",
        "shared/scrape-fast.js",
        "content.js"
      ],
      "css": ["button.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "shared/*",
        "shared/formats/*",
        "shared/main/*",
        "shared/sleep-worker.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ]
    }
  ]
}
