{
  "manifest_version": 3,
  "name": "Conversation Extractor for AI Websites",
  "description": "Export ChatGPT and Claude conversations to Markdown, JSON, or plain text.",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Conversation Extractor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"],
      "js": [
        "shared/namespace.js",
        "shared/download.js",
        "shared/format-registry.js",
        "shared/formats/markdown.js",
        "shared/formats/json.js",
        "shared/formats/txt.js",
        "shared/scrape-claude.js",
        "content.js"
      ],
      "css": ["button.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "shared/*",
        "shared/formats/*",
        "shared/sleep-worker.js"
      ],
      "matches": ["https://chatgpt.com/*", "https://claude.ai/*"]
    }
  ]
}
